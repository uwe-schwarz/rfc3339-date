{
  "name": "rfc3339-date",
  "version": "1.2.0",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "build:fonts": "node scripts/build-fonts.mjs",
    "build:openapi": "node scripts/build-openapi.mjs",
    "build:styles": "pnpm run build:fonts && pnpm run build:openapi && node scripts/build-tailwind.mjs",
    "check:component-lines": "node scripts/check-component-lines.mjs",
    "deps:visual": "node ./scripts/deps-visual-check.mjs",
    "deps:visual:install-browser": "playwright install chromium",
    "deps:visual:preview": "pnpm run build:styles && node scripts/run-deps-visual-preview.mjs",
    "dev": "pnpm run build:styles && wrangler dev",
    "start": "pnpm run build:styles && wrangler dev",
    "deploy": "pnpm run build:styles && wrangler deploy",
    "build": "pnpm run build:styles && wrangler deploy --dry-run",
    "checks": "pnpm run check:component-lines && pnpm run lint && pnpm run lint:openapi && pnpm run lint:openapi:scalar && pnpm run lint:scalar:project && pnpm run typecheck && pnpm run test && pnpm run build",
    "cf-typegen": "wrangler types",
    "format": "oxfmt src tests package.json tsconfig.json wrangler.jsonc",
    "lint": "oxlint .",
    "lint:openapi": "redocly lint docs/openapi.yaml",
    "lint:openapi:scalar": "node scripts/validate-openapi-scalar.mjs",
    "lint:scalar:project": "pnpm dlx --allow-build=esbuild --allow-build=vue-demi @scalar/cli project check-config scalar.config.json",
    "scalar:publish": "node scripts/publish-scalar.mjs",
    "scalar:preview": "pnpm dlx --allow-build=esbuild --allow-build=vue-demi @scalar/cli project preview scalar.config.json --no-open",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --pool=threads"
  },
  "dependencies": {
    "geist": "^1.7.2",
    "hono": "^4.12.25"
  },
  "devDependencies": {
    "@redocly/cli": "^2.31.6",
    "@scalar/openapi-parser": "^0.28.6",
    "@tailwindcss/cli": "^4.3.0",
    "@types/node": "^25.9.2",
    "next": "^16.2.7",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  }
}
